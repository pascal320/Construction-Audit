# Supabase connection pooler — session mode (IPv4, use this for Vercel)
# Format: postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.PROJECT-REF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Supabase direct connection — use for prisma migrate / prisma db seed (IPv6, local only)
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres"

# Anthropic API key — required for document upload extraction
ANTHROPIC_API_KEY="sk-ant-..."
